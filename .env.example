# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production

# Azure AD Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_TENANT_DOMAIN=yourdomain.onmicrosoft.com
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Admin Authentication
ADMIN_USERNAME=admin
# Generate password hash with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1$...
# For development only - use ADMIN_PASSWORD_HASH in production
ADMIN_PASSWORD=admin123

# Security Settings
LOGIN_ATTEMPTS_LIMIT=5
LOCKOUT_TIME_MINUTES=15

# Optional: Application Settings
LOG_LEVEL=INFO